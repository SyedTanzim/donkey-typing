# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (next.js / node.js)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt string replace tokens
.replacements

# Bower dependency directory (https://bower.io/)
bower_components

# node-modules (Crucial: prevents pushing thousands of heavy dependency files)
node_modules/
jspm_packages/

# Optional npm cache directory
.npm

# Output directory generated by vite/build
dist/
dist-ssr/
build/
out/

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Tern device definitions
.tern-port

# Stores VS Code settings and workspace configurations
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Operating System Files
.DS_Store
Thumbs.db

# Local environment files (Keeps your API keys/secrets safe if you add them later)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local